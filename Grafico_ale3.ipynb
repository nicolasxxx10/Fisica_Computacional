   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "x, y = [], []\n",
    "\n",
    "with open(\"datos_rand.txt\") as f:\n",
    "    for line in f:\n",
    "        a, b = map(int, line.split())\n",
    "        x.append(a)\n",
    "        y.append(b)\n",
    "\n",
    "plt.scatter(x, y, s=10)\n",
    "plt.title(\"Mersenne Twister\")\n",
    "plt.show()"
   ]
  }
 ],
